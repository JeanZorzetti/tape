---
import "../styles/global.css";
import { isPipeline, PIPELINES } from "../lib/adminUi";

interface Props {
  title: string;
  /** Some quando ninguém está logado (tela de login). */
  logado?: boolean;
}
const { title, logado = true } = Astro.props;

// Pipeline ativa vem da querystring; ausente = inbound. Preservada nos links de nav.
const pipelineParam = Astro.url.searchParams.get("pipeline") ?? "";
const pipeline = isPipeline(pipelineParam) ? pipelineParam : "inbound";
const comPipeline = (base: string) =>
  pipeline === "recuperacao" ? `${base}${base.includes("?") ? "&" : "?"}pipeline=recuperacao` : base;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title} · CRM TapePro</title>
  </head>
  <body class="flex min-h-screen flex-col bg-paper">
    <header class="border-b border-kraft/50 bg-white">
      <div class="mx-auto flex max-w-5xl items-center justify-between gap-4 px-4 py-3">
        <div class="flex items-center gap-6">
          <a href="/admin" class="font-display text-sm font-extrabold tracking-tight text-navy">
            TAPE<span class="text-orange">PRO</span>
            <span class="ml-2 font-mono text-[0.65rem] font-medium uppercase tracking-[0.2em] text-steel">CRM</span>
          </a>
          {
            logado && (
              <nav class="flex items-center gap-4 font-body text-sm font-medium text-steel">
                <a href={comPipeline("/admin")} class="hover:text-navy">Leads</a>
                <a href={comPipeline("/admin?visao=carteira")} class="hover:text-navy">Carteira</a>
                <a href={comPipeline("/admin/funil")} class="hover:text-navy">Funil</a>
              </nav>
            )
          }
        </div>
        {
          logado && (
            <div class="flex items-center gap-4">
              <nav aria-label="Pipeline" class="flex items-center rounded-full border border-kraft/60 bg-paper p-0.5">
                {Object.entries(PIPELINES).map(([value, cfg]) => (
                  <a
                    href={value === "recuperacao" ? "/admin?pipeline=recuperacao" : "/admin"}
                    aria-current={pipeline === value ? "page" : undefined}
                    class:list={[
                      "rounded-full px-3 py-1 font-body text-xs font-semibold",
                      pipeline === value ? "bg-navy text-white" : "text-steel hover:text-navy",
                    ]}
                  >
                    {cfg.label}
                  </a>
                ))}
              </nav>
              <form method="POST" action="/admin/sair">
                <button class="font-body text-sm font-medium text-steel hover:text-navy">Sair</button>
              </form>
            </div>
          )
        }
      </div>
    </header>

    <main class="mx-auto w-full max-w-5xl flex-1 px-4 py-8">
      <slot />
    </main>
  </body>
</html>
