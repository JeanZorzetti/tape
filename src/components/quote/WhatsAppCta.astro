---
import { whatsappLink } from "../../lib/whatsapp";

interface Props {
  label?: string;
  contexto?: string;
  paginaOrigem?: string;
  variant?: "primary" | "ghost" | "light";
  compact?: boolean;
}
const {
  label = "Pedir orçamento no WhatsApp",
  contexto,
  paginaOrigem,
  variant = "primary",
  compact = false,
} = Astro.props;

const href = whatsappLink(contexto, paginaOrigem);
const base =
  "inline-flex items-center justify-center gap-2 rounded-full font-body font-semibold transition focus-visible:outline";
const size = compact ? "px-4 py-2 text-sm" : "px-6 py-3.5 text-base";
const variants = {
  primary: "bg-orange text-navy hover:bg-orange-400 shadow-sm",
  ghost: "border border-white/30 text-white hover:bg-white/10",
  light: "bg-white text-navy hover:bg-kraft-100",
};
---

<a href={href} target="_blank" rel="noopener" class:list={[base, size, variants[variant]]}>
  <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
    <path
      d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2Zm5.8 14.16c-.24.68-1.42 1.32-1.96 1.36-.5.04-.98.22-3.3-.69-2.78-1.1-4.55-3.94-4.69-4.13-.14-.19-1.13-1.5-1.13-2.86s.71-2.03.97-2.31c.24-.28.53-.35.71-.35.18 0 .35 0 .5.01.16.01.38-.06.59.45.24.55.81 1.92.88 2.06.07.14.12.31.02.5-.09.19-.14.31-.28.48-.14.16-.29.37-.42.49-.14.14-.28.29-.12.57.16.28.72 1.18 1.54 1.91 1.06.94 1.95 1.23 2.23 1.37.28.14.44.12.6-.07.16-.19.69-.8.87-1.08.18-.28.37-.23.61-.14.24.09 1.55.73 1.81.87.28.14.46.21.53.32.07.12.07.68-.17 1.36Z"
    ></path>
  </svg>
  {label}
</a>
