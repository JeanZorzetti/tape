---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import JsonLd from "../../components/seo/JsonLd.astro";
import WhatsAppCta from "../../components/quote/WhatsAppCta.astro";
import { SITE_URL } from "../../lib/constants";

const ORIGEM = "Segmentos";

const segmentos = (await getCollection("segmentos")).sort((a, b) => a.data.ordem - b.data.ordem);

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Início", item: SITE_URL },
    { "@type": "ListItem", position: 2, name: "Segmentos", item: `${SITE_URL}/segmentos` },
  ],
};

const lista = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Segmentos atendidos pela TapePro",
  itemListElement: segmentos.map((s, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: s.data.titulo,
    url: `${SITE_URL}/segmentos/${s.id}`,
  })),
};
---

<BaseLayout
  title="Fita Adesiva Personalizada por Segmento: Indústria, Logística e E-commerce | TapePro"
  description="Qual fita cada operação precisa: indústria e expedição, distribuidoras, e-commerce, lojas e franquias. A dor de cada setor e a fita que resolve."
>
  <JsonLd data={breadcrumb} />
  <JsonLd data={lista} />

  <section class="bg-navy text-white">
    <div class="mx-auto max-w-6xl px-4 py-16 md:py-20">
      <nav aria-label="Trilha de navegação" class="font-mono text-[0.7rem] uppercase tracking-[0.18em] text-white/55">
        <a href="/" class="hover:text-orange">Início</a>
        <span class="px-2" aria-hidden="true">/</span>
        <span class="text-white/80">Segmentos</span>
      </nav>

      <p class="mt-8 font-mono text-xs uppercase tracking-[0.3em] text-orange">Aplicações · por operação</p>
      <h1 class="mt-5 max-w-3xl font-display text-[clamp(2.25rem,6vw,4rem)] font-extrabold leading-[0.95] tracking-[-0.03em]">
        A mesma fita resolve problemas diferentes.
      </h1>
      <p class="mt-6 max-w-2xl font-body text-lg leading-relaxed text-white/85">
        Uma indústria compra fita para não perder caixa no transporte. Um e-commerce compra para a marca chegar junto com
        o pedido. A escolha muda com a operação. Abaixo, o que cada setor enfrenta e qual das três fitas resolve.
      </p>
    </div>
  </section>

  <div class="mx-auto max-w-6xl px-4">
    {
      segmentos.map((s, i) => (
        <article class="grid gap-8 border-b border-kraft/50 py-14 md:grid-cols-12 md:gap-12 md:py-16">
          <div class="md:col-span-5">
            <a href={`/segmentos/${s.id}`} tabindex="-1" aria-hidden="true">
              <Image
                src={s.data.imagem}
                alt=""
                widths={[420, 720]}
                sizes="(min-width: 768px) 420px, 100vw"
                loading={i === 0 ? "eager" : "lazy"}
                class="aspect-[3/2] w-full rounded-2xl object-cover"
              />
            </a>
          </div>

          <div class="md:col-span-7">
            <p class="font-mono text-[0.7rem] uppercase tracking-[0.22em] text-steel">{s.data.eyebrow}</p>
            <h2 class="mt-3 text-2xl text-navy md:text-3xl">
              <a href={`/segmentos/${s.id}`} class="hover:text-orange-800">
                {s.data.titulo}
              </a>
            </h2>
            <p class="mt-4 max-w-xl font-display text-lg font-bold text-ink">{s.data.chamada}</p>
            <p class="mt-3 max-w-xl font-body leading-relaxed text-ink/75">{s.data.resumo}</p>

            <ul class="mt-7 space-y-2">
              {s.data.dores.slice(0, 3).map((d) => (
                <li class="flex gap-3 font-body text-sm text-ink/70">
                  <span class="mt-1.5 h-1.5 w-1.5 flex-none rounded-full bg-orange" aria-hidden="true" />
                  {d.titulo}
                </li>
              ))}
            </ul>

            <div class="mt-8">
              <a href={`/segmentos/${s.id}`} class="font-body text-sm font-semibold text-navy underline-offset-4 hover:underline">
                Ver o que resolve para {s.data.titulo.toLowerCase()} →
              </a>
            </div>
          </div>
        </article>
      ))
    }
  </div>

  <section class="bg-orange text-navy">
    <div class="mx-auto flex max-w-6xl flex-col items-start gap-6 px-4 py-16 md:flex-row md:items-center md:justify-between">
      <div>
        <h2 class="text-3xl md:text-4xl">Sua operação não está na lista?</h2>
        <p class="mt-3 max-w-lg font-body text-navy">
          Conte o peso da caixa, o volume mensal e o que precisa aparecer no lacre. A gente indica a fita e orça.
        </p>
      </div>
      <WhatsAppCta label="Falar no WhatsApp" paginaOrigem={`${ORIGEM} · CTA final`} variant="light" />
    </div>
  </section>
</BaseLayout>
