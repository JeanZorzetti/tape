---
export const prerender = false;

import AdminLayout from "../../layouts/AdminLayout.astro";
import { autenticar, bloqueado, criarSessao, sessaoAtual } from "../../lib/auth";

if (sessaoAtual(Astro.cookies)) return Astro.redirect("/admin");

const ip = Astro.clientAddress ?? "desconhecido";
let erro = "";
let email = "";

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  email = String(form.get("email") ?? "").trim();
  const senha = String(form.get("senha") ?? "");

  if (bloqueado(ip)) {
    erro = "Muitas tentativas. Espere alguns minutos.";
  } else {
    try {
      const usuario = await autenticar(email, senha, ip);
      if (usuario) {
        criarSessao(Astro.cookies, usuario.id);
        return Astro.redirect("/admin");
      }
      erro = "E-mail ou senha incorretos.";
    } catch (e) {
      console.error("[login] falha", e);
      erro = "Erro ao conectar no banco. Confira DATABASE_URL e SESSION_SECRET.";
    }
  }
}

const inputCls =
  "w-full rounded-lg border border-kraft/60 bg-white px-3.5 py-2.5 font-body text-ink focus:border-navy focus:outline-none";
---

<AdminLayout title="Entrar" logado={false}>
  <div class="mx-auto max-w-sm py-10">
    <h1 class="font-display text-2xl font-extrabold text-navy">Entrar no CRM</h1>
    <p class="mt-2 font-body text-sm text-steel">Painel interno de leads da TapePro.</p>

    {
      erro && (
        <p role="alert" class="mt-6 rounded-lg border border-[#b42318]/30 bg-[#b42318]/5 px-4 py-3 font-body text-sm text-[#b42318]">
          {erro}
        </p>
      )
    }

    <form method="POST" class="mt-6 grid gap-4">
      <div>
        <label for="email" class="mb-1.5 block font-body text-sm font-medium text-navy">E-mail</label>
        <input id="email" name="email" type="email" required autocomplete="username" value={email} class={inputCls} />
      </div>
      <div>
        <label for="senha" class="mb-1.5 block font-body text-sm font-medium text-navy">Senha</label>
        <input id="senha" name="senha" type="password" required autocomplete="current-password" class={inputCls} />
      </div>
      <button
        type="submit"
        class="mt-2 rounded-full bg-navy px-6 py-3 font-body font-semibold text-white transition hover:bg-navy-800"
      >
        Entrar
      </button>
    </form>
  </div>
</AdminLayout>
