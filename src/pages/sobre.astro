---
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import JsonLd from "../components/seo/JsonLd.astro";
import WhatsAppCta from "../components/quote/WhatsAppCta.astro";
import { CLIENTES, EMPRESAS_ATENDIDAS, PEDIDO_MINIMO_ROLOS, SITE_URL } from "../lib/constants";
import { PRODUTOS } from "../lib/produtos";
import deposito from "../assets/marca/deposito-tapepro.jpg";

const ORIGEM = "Sobre";

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Início", item: SITE_URL },
    { "@type": "ListItem", position: 2, name: "Sobre", item: `${SITE_URL}/sobre` },
  ],
};

const compromissos = [
  {
    titulo: "Pedido mínimo baixo de verdade",
    texto: `A partir de ${PEDIDO_MINIMO_ROLOS} rolos. Boa parte do mercado só produz a partir de 100 — quem está começando fica de fora, e não deveria.`,
  },
  {
    titulo: "Catálogo curto, sem enrolação",
    texto:
      "Três fitas, cada uma com um trabalho claro. Preferimos dizer qual delas resolve o seu caso a empurrar um catálogo inteiro.",
  },
  {
    titulo: "Orçamento sob medida",
    texto:
      "Preço de fita se faz por volume, arte e prazo. Você manda o cenário real, a gente devolve o número — sem cadastro, sem funil de e-mail.",
  },
  {
    titulo: "Produção que já roda",
    texto:
      "A fita é produzida pela TapePro, com clichê flexográfico próprio e impressão em até 2 cores. Nada disso é terceirizado no meio do caminho.",
  },
];
---

<BaseLayout
  title="Sobre a TapePro — Representante Comercial de Fitas Personalizadas"
  description="Representante comercial oficial da TapePro, fábrica de fitas adesivas personalizadas. Mais de 1.000 empresas atendidas e atendimento nacional."
>
  <JsonLd data={breadcrumb} />

  <section class="bg-navy text-white">
    <div class="mx-auto max-w-6xl px-4 py-16 md:py-20">
      <p class="font-mono text-xs uppercase tracking-[0.3em] text-orange">Quem atende você</p>
      <h1 class="mt-5 max-w-3xl font-display text-[clamp(2.25rem,6vw,4rem)] font-extrabold leading-[0.95] tracking-[-0.03em]">
        Representante comercial oficial da TapePro.
      </h1>
      <p class="mt-6 max-w-2xl font-body text-lg leading-relaxed text-white/85">
        A TapePro fabrica fitas adesivas personalizadas há anos e já imprimiu a marca de mais de {
          EMPRESAS_ATENDIDAS.toLocaleString("pt-BR")
        } empresas. Este site é o canal comercial dela: o mesmo produto, com atendimento direto de quem conhece a fita.
      </p>
    </div>
  </section>

  <section class="relative h-[38vh] min-h-[260px] overflow-hidden md:h-[46vh]">
    <Image
      src={deposito}
      alt="Galpão logístico com caixas lacradas por fita personalizada TapePro"
      loading="lazy"
      width={1920}
      widths={[768, 1280, 1920]}
      sizes="100vw"
      class="h-full w-full object-cover object-[68%_center]"
    />
  </section>

  <section class="mx-auto grid max-w-6xl gap-12 px-4 py-16 md:grid-cols-12 md:py-20">
    <div class="md:col-span-5">
      <h2 class="text-2xl text-navy md:text-3xl">O que a gente resolve</h2>
    </div>
    <div class="md:col-span-7">
      <p class="font-body text-lg leading-relaxed text-ink/80">
        Toda empresa que despacha caixa lacra caixa. A maioria faz isso com uma fita anônima, que só custa dinheiro. A
        fita personalizada faz o mesmo trabalho e ainda carrega a marca, o aviso de segurança e a sensação de pacote bem
        fechado — pelo preço de um insumo que você já compra.
      </p>
      <p class="mt-5 font-body leading-relaxed text-ink/70">
        Nosso papel é encurtar esse caminho: entender o peso da caixa, o volume mensal e o que precisa aparecer no lacre,
        indicar a fita certa entre as três e fechar o orçamento. Sem catálogo inflado e sem prometer o que a fábrica não
        produz.
      </p>

      <dl class="mt-12 space-y-8">
        {
          compromissos.map((c, i) => (
            <div class="flex gap-5">
              <span class="font-mono text-sm tabular-nums text-navy/40">{String(i + 1).padStart(2, "0")}</span>
              <div>
                <dt class="font-display text-base font-bold text-navy">{c.titulo}</dt>
                <dd class="mt-1.5 font-body text-sm leading-relaxed text-ink/75">{c.texto}</dd>
              </div>
            </div>
          ))
        }
      </dl>
    </div>
  </section>

  <section class="bg-kraft-100">
    <div class="mx-auto max-w-6xl px-4 py-16 md:py-20">
      <p class="font-mono text-xs uppercase tracking-[0.28em] text-orange-800">Prova social</p>
      <h2 class="mt-3 max-w-2xl text-2xl text-navy md:text-3xl">
        Marcas que já saem de casa lacradas com a própria identidade.
      </h2>
      <ul class="mt-10 flex flex-wrap gap-3">
        {
          CLIENTES.map((nome) => (
            <li class="rounded-full border border-navy/15 bg-white px-4 py-2 font-body text-sm font-medium text-navy">
              {nome}
            </li>
          ))
        }
      </ul>
      <p class="mt-8 font-body text-sm text-ink/70">
        Cases reais impressos pela TapePro — do jeans ao autopeças, da farmácia ao alimentício.
        <a href="/#portfolio" class="font-semibold text-navy underline-offset-4 hover:underline">Ver o portfólio →</a>
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-16">
    <h2 class="text-2xl text-navy md:text-3xl">O catálogo, em uma linha cada</h2>
    <ul class="mt-8 divide-y divide-kraft/60 border-y border-kraft/60">
      {
        PRODUTOS.map((p) => (
          <li>
            <a href={`/produtos/${p.slug}`} class="flex flex-wrap items-baseline justify-between gap-x-8 gap-y-1 py-5 group">
              <span class="font-display text-lg font-bold text-navy group-hover:text-orange-800">{p.nome}</span>
              <span class="font-body text-sm text-ink/70">{p.chamada}</span>
              <span class="font-mono text-[0.65rem] uppercase tracking-[0.18em] text-steel">{p.eyebrow}</span>
            </a>
          </li>
        ))
      }
    </ul>
  </section>

  <section class="bg-orange text-navy">
    <div class="mx-auto flex max-w-6xl flex-col items-start gap-6 px-4 py-16 md:flex-row md:items-center md:justify-between">
      <div>
        <h2 class="text-3xl md:text-4xl">Vamos imprimir a sua marca?</h2>
        <p class="mt-3 font-body text-navy">
          Fale direto com quem atende — sem intermediário e sem formulário obrigatório.
        </p>
      </div>
      <WhatsAppCta label="Falar no WhatsApp" paginaOrigem={ORIGEM} variant="light" />
    </div>
  </section>
</BaseLayout>
