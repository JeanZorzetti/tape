---
import BaseLayout from "../layouts/BaseLayout.astro";
import QuoteForm from "../components/quote/QuoteForm.astro";
import WhatsAppCta from "../components/quote/WhatsAppCta.astro";
import { PEDIDO_MINIMO_ROLOS, WHATSAPP_DISPLAY } from "../lib/constants";

const ORIGEM = "Orçamento";

const passos = [
  { t: "Você conta o que precisa", d: "Tipo de fita, sua arte ou marca, quantidade estimada e prazo." },
  { t: "Retornamos com o orçamento", d: "Preço por volume, opções de acabamento e prazo de produção." },
  { t: "Aprovou, a gente produz", d: "Produção sob medida e envio para todo o Brasil." },
];
---

<BaseLayout
  title="Peça seu orçamento de Fitas Personalizadas | TapePro"
  description="Peça orçamento de fitas adesivas personalizadas: transparente ou kraft, a partir de 20 rolos, até 2 cores. Resposta rápida no WhatsApp ou pelo formulário."
>
  <!-- INTRO -->
  <section class="bg-navy text-white">
    <div class="mx-auto max-w-6xl px-4 py-16 md:py-20">
      <p class="font-mono text-xs uppercase tracking-[0.3em] text-orange">Orçamento sem compromisso · B2B</p>
      <h1 class="mt-5 max-w-3xl font-display text-[clamp(2.25rem,6vw,4rem)] font-extrabold leading-[0.95] tracking-[-0.03em]">
        Peça seu orçamento de fita personalizada.
      </h1>
      <p class="mt-6 max-w-xl font-body text-lg leading-relaxed text-white/85">
        Conte o que você precisa e retornamos com preço, prazo e opções. A partir de {PEDIDO_MINIMO_ROLOS} rolos, com até 2
        cores, atendimento nacional.
      </p>
      <div class="mt-8 flex flex-wrap items-center gap-4">
        <WhatsAppCta label="Prefiro resolver no WhatsApp" paginaOrigem={ORIGEM} />
        <span class="font-mono text-xs uppercase tracking-widest text-white/55">Resposta rápida · {WHATSAPP_DISPLAY}</span>
      </div>
    </div>
  </section>

  <!-- FORM + SIDEBAR -->
  <section class="mx-auto grid max-w-6xl gap-12 px-4 py-16 md:grid-cols-12 md:py-20">
    <div class="md:col-span-7">
      <h2 class="text-2xl text-navy md:text-3xl">Formulário de orçamento</h2>
      <p class="mt-2 font-body text-ink/70">Campos com <span class="text-orange-800">*</span> são obrigatórios.</p>
      <div class="mt-8">
        <QuoteForm paginaOrigem={ORIGEM} />
      </div>
    </div>

    <aside class="md:col-span-5 md:pl-4">
      <div class="rounded-2xl border border-kraft/50 bg-kraft-100 p-7">
        <p class="font-mono text-xs uppercase tracking-[0.28em] text-orange-800">Como funciona</p>
        <ol class="mt-6 space-y-6">
          {
            passos.map((p, i) => (
              <li class="flex gap-4">
                <span class="font-mono text-sm font-medium text-navy/45 tabular-nums">
                  {String(i + 1).padStart(2, "0")}
                </span>
                <div>
                  <h3 class="font-display text-base font-bold text-navy">{p.t}</h3>
                  <p class="mt-1 font-body text-sm leading-relaxed text-ink/70">{p.d}</p>
                </div>
              </li>
            ))
          }
        </ol>
        <div class="mt-8 border-t border-navy/10 pt-6">
          <p class="font-body text-sm text-ink/70">Com pressa? Fale com a gente agora.</p>
          <div class="mt-3">
            <WhatsAppCta label="Falar no WhatsApp" paginaOrigem={`${ORIGEM} · sidebar`} variant="light" compact />
          </div>
        </div>
      </div>
    </aside>
  </section>
</BaseLayout>
