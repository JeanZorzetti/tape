---
import { Image } from "astro:assets";
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import JsonLd from "../../components/seo/JsonLd.astro";
import WhatsAppCta from "../../components/quote/WhatsAppCta.astro";
import { getProduto } from "../../lib/produtos";
import { SITE_URL, NOME_MARCA, PEDIDO_MINIMO_ROLOS } from "../../lib/constants";
import { formatarData, postsPublicados, postsRelacionados } from "../../lib/conteudo";

export async function getStaticPaths() {
  const posts = await postsPublicados();
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { data } = post;
const { Content } = await render(post);

const url = `${SITE_URL}/blog/${post.id}`;
const produtos = data.produtosRelacionados.map(getProduto).filter((p) => p !== undefined);
const relacionados = postsRelacionados(await postsPublicados(), post);

const segmentos = (await getCollection("segmentos")).filter((s) => data.segmentosRelacionados.includes(s.id));

const atualizadoEm = data.atualizadoEm ?? data.publicadoEm;

const blogPosting = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: data.titulo,
  description: data.descricao,
  image: new URL(data.imagem.src, SITE_URL).href,
  datePublished: data.publicadoEm.toISOString(),
  dateModified: atualizadoEm.toISOString(),
  author: { "@type": "Organization", name: NOME_MARCA, url: SITE_URL },
  publisher: { "@type": "Organization", name: NOME_MARCA, url: SITE_URL },
  mainEntityOfPage: url,
  inLanguage: "pt-BR",
};

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Início", item: SITE_URL },
    { "@type": "ListItem", position: 2, name: "Blog", item: `${SITE_URL}/blog` },
    { "@type": "ListItem", position: 3, name: data.titulo, item: url },
  ],
};
---

<BaseLayout title={`${data.titulo} | ${NOME_MARCA}`} description={data.descricao}>
  <JsonLd data={blogPosting} />
  <JsonLd data={breadcrumb} />

  <article>
    <!-- CABEÇALHO -->
    <header class="mx-auto max-w-6xl px-4 pt-10 md:pt-14">
      <nav aria-label="Trilha de navegação" class="font-mono text-[0.7rem] uppercase tracking-[0.18em] text-steel">
        <a href="/" class="hover:text-orange-800">Início</a>
        <span class="px-2" aria-hidden="true">/</span>
        <a href="/blog" class="hover:text-orange-800">Blog</a>
      </nav>

      <div class="mt-8 max-w-3xl">
        <p class="font-mono text-[0.7rem] uppercase tracking-[0.22em] text-orange-800">
          <time datetime={data.publicadoEm.toISOString()}>{formatarData(data.publicadoEm)}</time>
          <span class="px-2" aria-hidden="true">·</span>
          {data.tempoLeituraMin} min de leitura
        </p>
        <h1 class="mt-4 font-display text-[clamp(1.9rem,5vw,3.25rem)] font-extrabold leading-[1.02] tracking-[-0.03em] text-navy">
          {data.h1}
        </h1>
        <p class="mt-6 border-l-2 border-orange pl-5 font-body text-lg leading-relaxed text-ink/80">
          {data.resumo}
        </p>
      </div>
    </header>

    <figure class="mx-auto max-w-6xl px-4 pt-10">
      <Image
        src={data.imagem}
        alt={data.imagemAlt}
        widths={[720, 1200]}
        sizes="(min-width: 1152px) 1088px, 100vw"
        loading="eager"
        class="aspect-[3/2] w-full rounded-2xl object-cover md:aspect-[21/9]"
      />
    </figure>

    <!-- CORPO + TRILHO LATERAL -->
    <div class="mx-auto grid max-w-6xl gap-12 px-4 py-14 md:grid-cols-12 md:gap-16 md:py-16">
      <div class="prosa md:col-span-8">
        <Content />
      </div>

      <aside class="md:col-span-4">
        <div class="md:sticky md:top-28">
          {
            produtos.length > 0 && (
              <>
                <h2 class="font-mono text-xs uppercase tracking-[0.22em] text-steel">Fitas citadas</h2>
                <div class="mt-5 space-y-3">
                  {produtos.map((p) => (
                    <a
                      href={`/produtos/${p.slug}`}
                      class="flex items-center gap-4 rounded-xl border border-kraft/50 bg-white p-4 transition hover:border-orange"
                    >
                      <div class="flex h-14 w-14 flex-none items-center justify-center rounded-lg bg-white">
                        <Image src={p.imagem} alt="" loading="lazy" class="h-auto w-full object-contain" />
                      </div>
                      <div>
                        <h3 class="font-display text-sm font-bold leading-snug text-navy">{p.nome}</h3>
                        <p class="mt-0.5 font-mono text-[0.6rem] uppercase tracking-[0.16em] text-steel">{p.eyebrow}</p>
                      </div>
                    </a>
                  ))}
                </div>
              </>
            )
          }

          {
            segmentos.length > 0 && (
              <>
                <h2 class="mt-10 font-mono text-xs uppercase tracking-[0.22em] text-steel">Para a sua operação</h2>
                <ul class="mt-5 space-y-2.5">
                  {segmentos.map((s) => (
                    <li>
                      <a
                        href={`/segmentos/${s.id}`}
                        class="font-body text-sm font-semibold text-navy underline-offset-4 hover:text-orange-800 hover:underline"
                      >
                        {s.data.titulo} →
                      </a>
                    </li>
                  ))}
                </ul>
              </>
            )
          }

          <div class="mt-10 rounded-2xl bg-navy p-6 text-white">
            <p class="font-display text-lg font-bold leading-snug">Precisa de um número para o seu caso?</p>
            <p class="mt-2 font-body text-sm leading-relaxed text-white/75">
              Manda o peso da caixa e o volume mensal — a indicação e o orçamento voltam no mesmo dia.
            </p>
            <div class="mt-5">
              <WhatsAppCta label="Pedir orçamento" paginaOrigem={`Blog — ${data.titulo}`} compact />
            </div>
          </div>
        </div>
      </aside>
    </div>
  </article>

  {
    relacionados.length > 0 && (
      <section class="bg-kraft-100">
        <div class="mx-auto max-w-6xl px-4 py-16">
          <h2 class="text-2xl text-navy md:text-3xl">Continue lendo</h2>
          <div class="mt-8 grid gap-x-8 gap-y-10 sm:grid-cols-2 lg:grid-cols-3">
            {relacionados.map((p) => (
              <article>
                <a href={`/blog/${p.id}`} class="group block">
                  <Image
                    src={p.data.imagem}
                    alt=""
                    widths={[400, 800]}
                    sizes="(min-width: 1024px) 350px, (min-width: 640px) 45vw, 100vw"
                    loading="lazy"
                    class="aspect-[3/2] w-full rounded-xl object-cover"
                  />
                  <h3 class="mt-4 font-display text-base font-bold leading-snug text-navy group-hover:text-orange-800">
                    {p.data.titulo}
                  </h3>
                  <p class="mt-2 font-mono text-[0.65rem] uppercase tracking-[0.18em] text-steel">
                    {p.data.tempoLeituraMin} min
                  </p>
                </a>
              </article>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <section class="bg-orange text-navy">
    <div class="mx-auto flex max-w-6xl flex-col items-start gap-6 px-4 py-16 md:flex-row md:items-center md:justify-between">
      <div>
        <h2 class="text-3xl md:text-4xl">Vamos orçar a sua fita.</h2>
        <p class="mt-3 font-body text-navy">
          Resposta rápida no WhatsApp · a partir de {PEDIDO_MINIMO_ROLOS} rolos · atendimento nacional.
        </p>
      </div>
      <div class="flex flex-wrap items-center gap-4">
        <WhatsAppCta label="Falar no WhatsApp" paginaOrigem={`Blog — ${data.titulo} — CTA final`} variant="light" />
        <a href="/orcamento" class="font-body text-sm font-semibold text-navy underline-offset-4 hover:underline">
          Ou preencher o formulário →
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
