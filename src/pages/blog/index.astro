---
import { Image } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import JsonLd from "../../components/seo/JsonLd.astro";
import WhatsAppCta from "../../components/quote/WhatsAppCta.astro";
import { SITE_URL } from "../../lib/constants";
import { formatarData, postsPublicados } from "../../lib/conteudo";

const ORIGEM = "Blog";

const posts = await postsPublicados();
const [destaque, ...demais] = posts;

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Início", item: SITE_URL },
    { "@type": "ListItem", position: 2, name: "Blog", item: `${SITE_URL}/blog` },
  ],
};

const lista = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Blog TapePro — fitas adesivas e embalagem",
  itemListElement: posts.map((p, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: p.data.titulo,
    url: `${SITE_URL}/blog/${p.id}`,
  })),
};
---

<BaseLayout
  title="Blog — Fitas Adesivas, Lacre e Embalagem | TapePro"
  description="Conteúdo técnico sobre fita adesiva para embalagem: como escolher para caixa pesada, gomada × BOPP, clichê flexográfico, consumo mensal e avisos de segurança."
>
  <JsonLd data={breadcrumb} />
  <JsonLd data={lista} />

  <section class="bg-navy text-white">
    <div class="mx-auto max-w-6xl px-4 py-16 md:py-20">
      <nav aria-label="Trilha de navegação" class="font-mono text-[0.7rem] uppercase tracking-[0.18em] text-white/55">
        <a href="/" class="hover:text-orange">Início</a>
        <span class="px-2" aria-hidden="true">/</span>
        <span class="text-white/80">Blog</span>
      </nav>

      <p class="mt-8 font-mono text-xs uppercase tracking-[0.3em] text-orange">Conteúdo técnico</p>
      <h1 class="mt-5 max-w-3xl font-display text-[clamp(2.25rem,6vw,4rem)] font-extrabold leading-[0.95] tracking-[-0.03em]">
        O que ninguém explica sobre fita.
      </h1>
      <p class="mt-6 max-w-2xl font-body text-lg leading-relaxed text-white/85">
        Por que a fita descola, quando a plástica deixa de servir, como o preço é formado e o que vale imprimir no lacre.
        Sem enrolação e sem conteúdo genérico — o que a gente responde no WhatsApp todo dia, escrito por extenso.
      </p>
    </div>
  </section>

  <!-- DESTAQUE -->
  <section class="mx-auto max-w-6xl px-4 pt-14 md:pt-16">
    <a href={`/blog/${destaque.id}`} class="group grid gap-8 md:grid-cols-12 md:gap-12">
      <div class="md:col-span-7">
        <Image
          src={destaque.data.imagem}
          alt={destaque.data.imagemAlt}
          widths={[640, 1200]}
          sizes="(min-width: 768px) 620px, 100vw"
          loading="eager"
          class="aspect-[3/2] w-full rounded-2xl object-cover"
        />
      </div>
      <div class="flex flex-col justify-center md:col-span-5">
        <p class="font-mono text-[0.7rem] uppercase tracking-[0.22em] text-orange-800">Mais recente</p>
        <h2 class="mt-4 font-display text-2xl font-extrabold leading-tight tracking-[-0.02em] text-navy group-hover:text-orange-800 md:text-3xl">
          {destaque.data.titulo}
        </h2>
        <p class="mt-4 font-body leading-relaxed text-ink/75">{destaque.data.descricao}</p>
        <p class="mt-5 font-mono text-[0.7rem] uppercase tracking-[0.18em] text-steel">
          <time datetime={destaque.data.publicadoEm.toISOString()}>{formatarData(destaque.data.publicadoEm)}</time>
          <span class="px-2" aria-hidden="true">·</span>
          {destaque.data.tempoLeituraMin} min de leitura
        </p>
      </div>
    </a>
  </section>

  <!-- DEMAIS POSTS -->
  <section class="mx-auto max-w-6xl px-4 py-14 md:py-16">
    <h2 class="sr-only">Todos os artigos</h2>
    <div class="grid gap-x-8 gap-y-12 sm:grid-cols-2 lg:grid-cols-3">
      {
        demais.map((post) => (
          <article>
            <a href={`/blog/${post.id}`} class="group block">
              <Image
                src={post.data.imagem}
                alt={post.data.imagemAlt}
                widths={[400, 800]}
                sizes="(min-width: 1024px) 350px, (min-width: 640px) 45vw, 100vw"
                loading="lazy"
                class="aspect-[3/2] w-full rounded-xl object-cover"
              />
              <h3 class="mt-5 font-display text-lg font-bold leading-snug text-navy group-hover:text-orange-800">
                {post.data.titulo}
              </h3>
              <p class="mt-2.5 font-body text-sm leading-relaxed text-ink/70">{post.data.descricao}</p>
              <p class="mt-4 font-mono text-[0.65rem] uppercase tracking-[0.18em] text-steel">
                <time datetime={post.data.publicadoEm.toISOString()}>{formatarData(post.data.publicadoEm)}</time>
                <span class="px-2" aria-hidden="true">·</span>
                {post.data.tempoLeituraMin} min
              </p>
            </a>
          </article>
        ))
      }
    </div>
  </section>

  <section class="bg-orange text-navy">
    <div class="mx-auto flex max-w-6xl flex-col items-start gap-6 px-4 py-16 md:flex-row md:items-center md:justify-between">
      <div>
        <h2 class="text-3xl md:text-4xl">Ficou com dúvida sobre a sua caixa?</h2>
        <p class="mt-3 max-w-lg font-body text-navy">
          Manda o peso, o volume mensal e o que precisa aparecer no lacre — a gente indica a fita e orça.
        </p>
      </div>
      <WhatsAppCta label="Falar no WhatsApp" paginaOrigem={`${ORIGEM} — CTA final`} variant="light" />
    </div>
  </section>
</BaseLayout>
