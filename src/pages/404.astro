---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import TapeStrip from "../components/ui/TapeStrip.astro";
import WhatsAppCta from "../components/quote/WhatsAppCta.astro";
import { PRODUTOS } from "../lib/produtos";
import { postsPublicados } from "../lib/conteudo";

const ORIGEM = "Página não encontrada";

const segmentos = (await getCollection("segmentos")).sort((a, b) => a.data.ordem - b.data.ordem);
const posts = (await postsPublicados()).slice(0, 3);

// O site tem 21 páginas: listar tudo resolve melhor que um campo de busca com JS.
const atalhos = [
  { href: "/blog", titulo: "Blog", texto: "Como escolher, quanto pedir, por que a fita descola." },
  { href: "/perguntas-frequentes", titulo: "Perguntas frequentes", texto: "Prazo, mínimo, cores, clichê e entrega." },
  { href: "/orcamento", titulo: "Orçamento", texto: "Formulário com o que a gente precisa saber para orçar." },
];
---

<BaseLayout
  title="Página não encontrada (404) | TapePro"
  description="A página que você procurava não existe mais. Veja as fitas, os segmentos atendidos e fale com a gente no WhatsApp."
  noindex
>
  <section class="bg-navy text-white">
    <div class="mx-auto max-w-6xl px-4 py-16 md:py-24">
      <p class="font-mono text-xs uppercase tracking-[0.3em] text-orange">Erro 404 · página não encontrada</p>
      <h1 class="mt-5 max-w-3xl font-display text-[clamp(2.25rem,6vw,4rem)] font-extrabold leading-[0.95] tracking-[-0.03em]">
        Essa página descolou.
      </h1>
      <p class="mt-6 max-w-2xl font-body text-lg leading-relaxed text-white/85">
        O endereço mudou ou nunca existiu. O catálogo inteiro está logo abaixo — três fitas, quatro operações e o que
        escrevemos sobre cada uma delas.
      </p>
    </div>
  </section>
  <TapeStrip />

  <div class="mx-auto grid max-w-6xl gap-12 px-4 py-16 md:grid-cols-12 md:py-20">
    <section class="md:col-span-7" aria-labelledby="as-fitas">
      <h2 id="as-fitas" class="text-2xl text-navy md:text-3xl">As fitas</h2>
      <ul class="mt-8 divide-y divide-kraft/50 border-y border-kraft/50">
        {
          PRODUTOS.map((p) => (
            <li class="py-5">
              <a href={`/produtos/${p.slug}`} class="group block">
                <span class="font-display text-lg font-bold text-navy group-hover:text-orange-800">{p.nome}</span>
                <span class="mt-1 block font-body text-sm text-ink/75">{p.chamada}</span>
              </a>
            </li>
          ))
        }
      </ul>
      <p class="mt-6">
        <a href="/produtos" class="font-body text-sm font-semibold text-navy underline-offset-4 hover:underline">
          Ver a comparação das três fitas →
        </a>
      </p>

      <h2 class="mt-14 text-2xl text-navy md:text-3xl">Leituras recentes</h2>
      <ul class="mt-6 space-y-4">
        {
          posts.map((post) => (
            <li>
              <a href={`/blog/${post.id}`} class="font-body font-semibold text-navy underline-offset-4 hover:text-orange-800 hover:underline">
                {post.data.titulo}
              </a>
            </li>
          ))
        }
      </ul>
    </section>

    <aside class="md:col-span-5">
      <section aria-labelledby="por-operacao" class="rounded-2xl bg-kraft-100 p-7">
        <h2 id="por-operacao" class="font-display text-lg font-bold text-navy">Por operação</h2>
        <ul class="mt-5 space-y-3 font-body text-sm">
          {
            segmentos.map((s) => (
              <li>
                <a href={`/segmentos/${s.id}`} class="font-semibold text-navy underline-offset-4 hover:text-orange-800 hover:underline">
                  {s.data.titulo}
                </a>
              </li>
            ))
          }
        </ul>
      </section>

      <nav aria-label="Atalhos" class="mt-8">
        <ul class="space-y-5">
          {
            atalhos.map((a) => (
              <li>
                <a href={a.href} class="group block">
                  <span class="font-display font-bold text-navy group-hover:text-orange-800">{a.titulo}</span>
                  <span class="mt-0.5 block font-body text-sm text-ink/75">{a.texto}</span>
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </aside>
  </div>

  <section class="bg-orange text-navy">
    <div class="mx-auto flex max-w-6xl flex-col items-start gap-6 px-4 py-16 md:flex-row md:items-center md:justify-between">
      <div>
        <h2 class="text-3xl md:text-4xl">Prefere resolver falando?</h2>
        <p class="mt-3 max-w-lg font-body text-navy">
          Diga o peso da caixa, o volume por mês e o que precisa aparecer no lacre — a gente indica a fita e orça.
        </p>
      </div>
      <WhatsAppCta label="Falar no WhatsApp" paginaOrigem={ORIGEM} variant="light" />
    </div>
  </section>
</BaseLayout>
