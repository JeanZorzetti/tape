---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import JsonLd from "../components/seo/JsonLd.astro";
import WhatsAppCta from "../components/quote/WhatsAppCta.astro";
import TapeStrip from "../components/ui/TapeStrip.astro";
import { PRODUTOS } from "../lib/produtos";
import { SITE_URL, PEDIDO_MINIMO_ROLOS, WHATSAPP_DISPLAY } from "../lib/constants";

const ORIGEM = "Perguntas frequentes";

// Único FAQPage do site: a FAQ do clichê em /produtos/fita-transparente-personalizada
// renderiza sem JSON-LD de propósito, para não duplicar o schema.
const perguntas = (await getCollection("faq")).sort((a, b) => a.data.ordem - b.data.ordem);

const GRUPOS = [
  { id: "pedido", titulo: "Pedido e orçamento", texto: "Mínimos, prazos, como o preço é formado." },
  { id: "produto", titulo: "Produtos e técnica", texto: "Qual fita serve para cada caixa e por que." },
  { id: "personalizacao", titulo: "Personalização e clichê", texto: "Arte, cores e a matriz de impressão." },
  { id: "entrega", titulo: "Entrega", texto: "Cobertura e frete." },
] as const;

const porGrupo = GRUPOS.map((grupo) => ({
  ...grupo,
  itens: perguntas.filter((p) => p.data.grupo === grupo.id),
})).filter((g) => g.itens.length > 0);

const faqPage = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: perguntas.map((p) => ({
    "@type": "Question",
    name: p.data.pergunta,
    acceptedAnswer: { "@type": "Answer", text: p.data.resposta },
  })),
};

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Início", item: SITE_URL },
    { "@type": "ListItem", position: 2, name: "Perguntas frequentes", item: `${SITE_URL}/perguntas-frequentes` },
  ],
};
---

<BaseLayout
  title="Perguntas Frequentes sobre Fita Adesiva Personalizada | TapePro"
  description="Pedido mínimo, prazo, clichê flexográfico, número de cores, qual fita usar em caixa pesada e como calcular o consumo mensal da sua operação."
>
  <JsonLd data={faqPage} />
  <JsonLd data={breadcrumb} />

  <section class="bg-navy text-white">
    <div class="mx-auto max-w-6xl px-4 py-14 md:py-16">
      <nav aria-label="Trilha de navegação" class="font-mono text-[0.7rem] uppercase tracking-[0.18em] text-white/55">
        <a href="/" class="hover:text-orange">Início</a>
        <span class="px-2" aria-hidden="true">/</span>
        <span class="text-white/80">Perguntas frequentes</span>
      </nav>

      <p class="mt-8 font-mono text-xs uppercase tracking-[0.3em] text-orange">Dúvidas · direto ao ponto</p>
      <h1 class="mt-4 max-w-3xl font-display text-[clamp(2rem,5.5vw,3.75rem)] font-extrabold leading-[0.98] tracking-[-0.03em]">
        Perguntas frequentes
      </h1>
      <p class="mt-6 max-w-2xl font-body text-lg leading-relaxed text-white/85">
        O que mais chega no WhatsApp, respondido por extenso. Se a sua dúvida não estiver aqui, manda mensagem — a
        resposta costuma sair no mesmo dia.
      </p>
    </div>
    <TapeStrip tone="orange" class="relative z-10" />
  </section>

  <div class="mx-auto grid max-w-6xl gap-12 px-4 py-16 md:grid-cols-12 md:gap-16 md:py-20">
    <!-- ÍNDICE -->
    <nav aria-label="Seções da FAQ" class="md:col-span-4">
      <div class="md:sticky md:top-28">
        <h2 class="font-mono text-xs uppercase tracking-[0.22em] text-steel">Nesta página</h2>
        <ul class="mt-5 space-y-4">
          {
            porGrupo.map((g) => (
              <li>
                <a href={`#${g.id}`} class="group block">
                  <span class="font-display text-base font-bold text-navy group-hover:text-orange-800">{g.titulo}</span>
                  <span class="mt-0.5 block font-body text-sm text-ink/70">{g.texto}</span>
                </a>
              </li>
            ))
          }
        </ul>

        <div class="mt-10 rounded-2xl bg-kraft-100 p-6">
          <p class="font-display text-base font-bold leading-snug text-navy">Não achou a sua pergunta?</p>
          <p class="mt-2 font-body text-sm leading-relaxed text-ink/70">
            Chame no {WHATSAPP_DISPLAY} — a partir de {PEDIDO_MINIMO_ROLOS} rolos, atendimento nacional.
          </p>
          <div class="mt-5">
            <WhatsAppCta label="Tirar dúvida no WhatsApp" paginaOrigem={ORIGEM} compact />
          </div>
        </div>
      </div>
    </nav>

    <!-- PERGUNTAS -->
    <div class="md:col-span-8">
      {
        porGrupo.map((g) => (
          <section id={g.id} class="scroll-mt-28 [&+&]:mt-16">
            <h2 class="text-2xl text-navy md:text-3xl">{g.titulo}</h2>
            <div class="mt-6 divide-y divide-navy/10 border-y border-navy/10">
              {g.itens.map((p) => (
                <details class="group py-5">
                  <summary class="flex cursor-pointer list-none items-start justify-between gap-6 font-body font-semibold text-navy">
                    <h3 class="font-body text-base font-semibold">{p.data.pergunta}</h3>
                    <span
                      class="mt-0.5 font-mono text-lg leading-none text-orange-800 transition group-open:rotate-45"
                      aria-hidden="true"
                    >
                      +
                    </span>
                  </summary>
                  <p class="mt-3 max-w-2xl font-body leading-relaxed text-ink/75">{p.data.resposta}</p>
                </details>
              ))}
            </div>
          </section>
        ))
      }

      <!-- CAMINHOS DE APROFUNDAMENTO -->
      <section class="mt-16">
        <h2 class="text-2xl text-navy md:text-3xl">Para se aprofundar</h2>
        <div class="mt-6 grid gap-3 sm:grid-cols-2">
          {
            PRODUTOS.map((p) => (
              <a
                href={`/produtos/${p.slug}`}
                class="rounded-xl border border-kraft/50 bg-white p-4 transition hover:border-orange"
              >
                <p class="font-mono text-[0.6rem] uppercase tracking-[0.18em] text-steel">{p.eyebrow}</p>
                <p class="mt-1 font-display text-sm font-bold text-navy">{p.nome}</p>
              </a>
            ))
          }
          <a
            href="/blog"
            class="rounded-xl border border-kraft/50 bg-white p-4 transition hover:border-orange"
          >
            <p class="font-mono text-[0.6rem] uppercase tracking-[0.18em] text-steel">Conteúdo técnico</p>
            <p class="mt-1 font-display text-sm font-bold text-navy">Blog — como escolher, quanto custa, por que descola</p>
          </a>
        </div>
      </section>
    </div>
  </div>

  <section class="bg-orange text-navy">
    <div class="mx-auto flex max-w-6xl flex-col items-start gap-6 px-4 py-16 md:flex-row md:items-center md:justify-between">
      <div>
        <h2 class="text-3xl md:text-4xl">Ainda com dúvida? Pergunta direto.</h2>
        <p class="mt-3 font-body text-navy">
          Resposta rápida no WhatsApp · a partir de {PEDIDO_MINIMO_ROLOS} rolos · atendimento nacional.
        </p>
      </div>
      <div class="flex flex-wrap items-center gap-4">
        <WhatsAppCta label="Falar no WhatsApp" paginaOrigem={`${ORIGEM} — CTA final`} variant="light" />
        <a href="/orcamento" class="font-body text-sm font-semibold text-navy underline-offset-4 hover:underline">
          Ou preencher o formulário →
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
