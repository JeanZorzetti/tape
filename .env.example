# Postgres da VPS (Easypanel). O site estático builda sem isto;
# só /admin e /api/lead precisam do banco em runtime.
DATABASE_URL=postgres://usuario:senha@host:5432/tapepro

# Segredo que assina o cookie de sessão do /admin — mínimo 32 caracteres.
# Gerar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Primeiro acesso ao /admin: se ainda não existe nenhum usuário, o login com
# estas credenciais cria a conta (a senha é gravada com hash scrypt).
ADMIN_EMAIL=
ADMIN_SENHA=
